# ============================================================
# HormiQual — Módulo de Calidad (vitrina)
# Variables de entorno del FRONTEND
# ============================================================
# Copiá este archivo a `.env`. Los valores por defecto sirven para una
# instalación local estándar (backend en el puerto 3002).

# URL del backend.
REACT_APP_BACKEND_URL=http://localhost:3002

# Modo desarrollo/demo del frontend.
REACT_APP_TEST=true
