# ============================================================
# HormiQual — Módulo de Calidad (vitrina)
# Variables de entorno del BACKEND
# ============================================================
# Copiá este archivo a `.env`. Para una instalación local estándar
# (MySQL en 127.0.0.1, usuario `root` sin contraseña) los valores de abajo
# ya son válidos: lo único que conviene cambiar es SECRET_KEY.

# Entorno de ejecución.
APP_ENV=development

# ------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------
# El sistema es multi-tenant (una base por cliente). En la vitrina hay un
# único tenant llamado "vitrina". DEV_TENANT define cuál se usa en desarrollo.
DEV_TENANT=vitrina

# Conexión a la base del tenant "vitrina".
DATABASE_VITRINA=hormiqual_vitrina
DB_USERNAME_VITRINA=root
DB_PASSWORD_VITRINA=
DB_HOST_VITRINA=127.0.0.1

# ------------------------------------------------------------
# SEGURIDAD
# ------------------------------------------------------------
# Clave para firmar los JWT. En desarrollo cualquier cadena larga sirve.
# Podés generar una con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=cambiar_por_una_cadena_larga_y_aleatoria

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
# "*" permite cualquier origen (apto solo para desarrollo/demo local).
CORS_ORIGINS=*
